│   └── demo.py                        # Demo agents
├── templates/
│   └── index.html                     # Dashboard UI
├── tests/
│   └── test_hospital_triage.py        # Test suite
├── hospital_api.py                    # Flask API server
├── run_dashboard.py                   # Dashboard startup script
├── setup.py                           # Package setup
├── requirements.txt                   # Dependencies
├── Dockerfile                         # Docker image
├── docker-compose.yml                 # Docker Compose
├── DASHBOARD_README.md                # Dashboard documentation
└── README.md                          # This file
```

## Docker Usage

### Build Image

```bash
docker build -t hospital-triage:latest .
```

### Run Container

```bash
# Run demo
docker run hospital-triage:latest

# Run with volume mount for development
docker run -v $(pwd):/app hospital-triage:latest python scripts/demo.py
```

### Using Docker Compose

```bash
# Start service
docker-compose up

# Run command
docker-compose exec hospital-triage python scripts/demo.py

# Stop service
docker-compose down
```

## Training Custom Agents

Example using Stable-Baselines3:

```python
import gymnasium as gym
from stable_baselines3 import PPO
import hospital_triage

# Create environment
env = gym.make('HospitalTriage-v0')

# Train agent
model = PPO('MlpPolicy', env, verbose=1)
model.learn(total_timesteps=100000)

# Save model
model.save("hospital_triage_ppo")

# Load and evaluate
model = PPO.load("hospital_triage_ppo")
obs, info = env.reset()
for _ in range(100):
    action, _ = model.predict(obs)
    obs, reward, terminated, truncated, info = env.step(action)
    if terminated or truncated:
        break

env.close()
```

## Performance Metrics

Track agent performance with environment info:

```python
obs, info = env.reset()
for step in range(1000):
    action = env.action_space.sample()
    obs, reward, terminated, truncated, info = env.step(action)
    
    # Access metrics
    print(f"Queue: {info['queue_length']}")
    print(f"Admitted: {info['admitted_count']}")
    print(f"Avg Wait Time: {info['avg_waiting_time']:.1f}")
```

